import std
improt prelude
import create::a

print = prelude::io::print
add = prelude::math::add
mul = prelude::math::mul
pair a b f = f a b
first p = p (\x y -> x)
second p = p (\x y -> y)

infix 2 + a b = add a b
infix 3 * a b = mul a b
public infix 1 left $ a b = a b

main = print $ (first (pair 5 6)) + 5 * 3
