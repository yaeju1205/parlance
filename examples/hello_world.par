import pre

print = prelude::io::print
add = prelude::math::add
mul = prelude::math::mul

infix 2 + a b = add a b
infix 3 * a b = mul a b
infix 1 right $ a b = a b

pair x y f = f x y
first p = p $ \x y -> x
second p = p $ \x y -> y

a b c = let
    result = b + c
in
    result

main = print $ a 2 3
